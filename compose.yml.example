# Aquifer Docker Compose – copy to compose.yml and adjust to your setup.
#
# Both services bind-mount the current directory into /app so that
# aquifer.toml and aquifer.db live alongside the repository on the host.

services:

  meter:
    # Continuously polls the water meter and records readings to the database.
    build:
      context: .
      dockerfile: Dockerfile.meter
    volumes:
      - .:/app              # Mount repo root; place aquifer.toml and aquifer.db here

  dashboard:
    # Serves the storage-estimation dashboard on port 8050.
    build:
      context: .
      dockerfile: Dockerfile.dashboard
    ports:
      - "8050:8050"         # Expose the dashboard to the host
    volumes:
      - .:/app              # Mount repo root; place aquifer.toml and aquifer.db here
    depends_on:
      - meter
